VITE_API_BASE_URL=http://localhost:8787
VITE_API_BASE_PATH=/api/v1
VITE_TURNSTILE_SITE_KEY=your-site-key-here
VITE_DISABLE_TURNSTILE=false
VITE_TURNSTILE_TOKEN_URL=https://example.com/turnstile
VITE_ENABLE_TURNSTILE_TOKEN=false
VITE_THREAD_CACHE_GEN=20
VITE_POST_CACHE_GEN=30

# 削除されたレスの表示設定（空文字またはコメントアウトするとAPIの値をそのまま表示）
# VITE_DELETED_POST_NAME=（削除）
# VITE_DELETED_POST_ID=（削除）
# VITE_DELETED_POST_BODY=このレスは削除されました

# アプリブランディング
# VITE_APP_NAME=AnonBoard
# VITE_APP_ICON=/icon.png       # サイドバー等に表示するアイコン（publicディレクトリに配置したpng/svgファイルのパス）
# VITE_APP_FAVICON=/favicon.png # ブラウザタブのfavicon（未設定時は /favicon.svg を使用）
